# extrudeai/freecad-addon — public bootstrap repo .gitignore
#
# CRITICAL: `versions/` is the directory where the addon's `_firstrun.py`
# downloads the proprietary mixin code (~50 MB) on first launch. It is
# user data — never check it in here, AND never let the FreeCAD Addon
# Manager wipe it on update. Listing it here ensures `git pull` / `git
# fetch + reset --hard` treat it as untracked-and-keep.
versions/

# Python bytecode caches FreeCAD creates next to the bootstrap files.
__pycache__/
*.pyc
*.pyo

# macOS / editor cruft that occasionally lands in a Mod/ directory.
.DS_Store
*.swp
*~
